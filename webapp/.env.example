# Copy to `.env` and adjust for your setup. Auto-loaded by the justfile.
# See config.py for the app defaults.

# Server bind address (read natively by uvicorn).
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Serial link to the MotionDriver.
# "auto" lets the app detect the port; set explicitly on Linux/Pi or macOS, e.g.
#   /dev/ttyUSB0  or  /dev/cu.usbserial-11220
MOTIONDRIVER_SERIAL_PORT=auto
MOTIONDRIVER_SERIAL_BAUDRATE=115200
MOTIONDRIVER_SERIAL_TIMEOUT=1.0

# Background PING cadence (seconds) that feeds the firmware deadman.
# Keep well under the ESP32's 1.0s window. Set <= 0 to disable.
MOTIONDRIVER_HEARTBEAT_INTERVAL=0.2

# Use an in-memory stub instead of real serial hardware (1/true to enable).
MOTIONDRIVER_DRY_RUN=0

# Log command/response traffic (1/true to enable, 0 to silence).
MOTIONDRIVER_LOG_TRAFFIC=1
